#!/bin/bash
set -euo pipefail

ROOT=/workspace/rollup
PID_DIR="$ROOT/runtime/pids"

if [[ ! -d "$PID_DIR" ]]; then
  exit 0
fi

for pid_file in "$PID_DIR"/*.pid; do
  [[ -e "$pid_file" ]] || continue
  pid="$(cat "$pid_file")"
  if kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
    wait "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
done
