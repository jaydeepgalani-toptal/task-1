#!/bin/bash
set -euo pipefail

ROOT=/workspace/rollup
STATE_DIR="$ROOT/runtime/mock-state"
PID_DIR="$ROOT/runtime/pids"
FIXTURES_ROOT="$ROOT/fixtures/current"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --fixtures-root)
      FIXTURES_ROOT="$2"
      shift 2
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

mkdir -p "$STATE_DIR" "$PID_DIR" "$ROOT/logs"
/usr/local/bin/stop-rollup-mocks >/dev/null 2>&1 || true

start_one() {
  local partner="$1"
  local port="$2"
  local log_path="$ROOT/logs/mock-${partner}.log"
  node "$ROOT/mock/server.mjs" \
    --partner "$partner" \
    --port "$port" \
    --fixtures-root "$FIXTURES_ROOT" \
    --state-dir "$STATE_DIR" \
    >"$log_path" 2>&1 &
  echo $! > "$PID_DIR/${partner}.pid"
}

start_one alpha 4101
start_one beta 4102
start_one gamma 4103
start_one delta 4104

for port in 4101 4102 4103 4104; do
  for _ in $(seq 1 50); do
    if curl -fsS "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
  curl -fsS "http://127.0.0.1:${port}/health" >/dev/null
done
